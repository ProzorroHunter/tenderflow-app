# Настройки базы данных (пока для локальной разработки)
DATABASE_URL=postgresql://user:password@localhost:5432/prozorrohunter

# Telegram (замени на свои реальные значения позже)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username

# Prozorro API (публичный, ничего менять не нужно)
PROZORRO_API_BASE=https://public-api.prozorro.gov.ua/api/2.5

# Redis для Celery (для локального запуска)
REDIS_URL=redis://localhost:6379/0

# Приложение
SECRET_KEY=super-secret-key-change-in-production
DEBUG=True