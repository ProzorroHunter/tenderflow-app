# === База данных ===
DATABASE_URL=postgresql://user:password@localhost:5432/prozorrohunter

# === Telegram ===
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID канала (начинается с @) или chat_id
TELEGRAM_CHANNEL_ID=@your_channel_name

# === Prozorro API ===
PROZORRO_API_BASE=https://public-api.prozorro.gov.ua/api/2.5

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Безопасность ===
# Сгенерируйте надежный ключ: openssl rand -hex 32
SECRET_KEY=super-secret-key-change-in-production

# === Режим разработки ===
DEBUG=True

# === API URL (для бота) ===
API_BASE_URL=http://localhost:8000
